{
  "rewrites": [
    {
      "source": "/share/f/:slug/:title",
      "destination": "/api/share/f/:slug/:title"
    },
    {
      "source": "/share/:title",
      "destination": "/api/share/:title"
    },
    {
      "source": "/((?!api|share|assets|icons|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
